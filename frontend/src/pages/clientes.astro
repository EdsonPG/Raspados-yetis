---
/**
 * Página: Clientes (CRM)
 *
 * Tabla para gestionar el directorio de clientes.
 *
 * Consume: GET /api/v1/clientes
 * Envía:   POST /api/v1/clientes
 */
import Layout from '../layouts/Layout.astro';
---

<Layout titulo="Clientes" descripcion="Directorio de clientes — Raspados Yeti ERP">

  <!-- Cabecera de la vista -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h3 class="text-2xl font-bold text-texto-900">Directorio de Clientes</h3>
      <p class="text-texto-500 mt-1">Gestiona los datos de contacto y expediente de clientes</p>
    </div>
    <button id="btn-agregar-cliente"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-yeti-600 text-white text-sm font-medium rounded-lg
                   hover:bg-yeti-700 active:bg-yeti-800 shadow-sm hover:shadow-md
                   focus:outline-none focus:ring-2 focus:ring-yeti-500 focus:ring-offset-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM3 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
      </svg>
      Nuevo Cliente
    </button>
  </div>

  <!-- Tabla de clientes -->
  <div class="bg-white rounded-xl border border-superficie-200 shadow-card overflow-hidden">

    <div class="px-6 py-4 border-b border-superficie-200 flex items-center justify-between bg-superficie-50/50">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-texto-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input type="text" id="buscar-cliente" placeholder="Buscar cliente..."
               class="pl-10 pr-4 py-2 w-72 text-sm border border-superficie-200 rounded-lg bg-white
                      focus:outline-none focus:ring-2 focus:ring-yeti-500/30 focus:border-yeti-400
                      placeholder:text-texto-400" />
      </div>
      <p id="contador-clientes" class="text-xs text-texto-400">Cargando...</p>
    </div>

    <!-- Tabla -->
    <div class="overflow-x-auto">
      <table class="w-full" id="tabla-clientes">
        <thead>
          <tr class="bg-superficie-50 border-b border-superficie-200">
            <th class="text-left px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">ID</th>
            <th class="text-left px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">Nombre</th>
            <th class="text-left px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">Teléfono</th>
            <th class="text-left px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">Email</th>
            <th class="text-center px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">Eventos</th>
            <th class="text-center px-6 py-3 text-[11px] font-semibold uppercase tracking-wider text-texto-500">Acciones</th>
          </tr>
        </thead>
        <tbody id="tbody-clientes" class="divide-y divide-superficie-100">
          <tr id="skeleton-row">
            <td colspan="6" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center gap-3">
                <div class="w-8 h-8 border-2 border-yeti-300 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-sm text-texto-400">Cargando clientes...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 border-t border-superficie-200 flex items-center justify-between bg-superficie-50/50">
      <p id="info-paginacion" class="text-xs text-texto-400">—</p>
      <div class="flex gap-1" id="controles-paginacion"></div>
    </div>
  </div>

  <!-- Modal Crear/Editar Cliente -->
  <div id="modal-overlay" class="fixed inset-0 bg-texto-900/50 backdrop-blur-sm hidden items-center justify-center z-50">
    <div id="modal-contenido" class="bg-white rounded-xl shadow-xl w-full max-w-lg transform scale-95 opacity-0 transition-all duration-200 p-6">
      
      <div class="flex items-center justify-between mb-5">
        <h4 id="titulo-modal" class="text-lg font-bold text-texto-900">Nuevo Cliente</h4>
        <button id="btn-cerrar-modal" class="text-texto-400 hover:text-texto-700 bg-superficie-50 hover:bg-superficie-100 rounded-lg p-1.5 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="error-form" class="hidden mb-4 p-3 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm"></div>

      <form id="form-cliente" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-texto-700 mb-1">Nombre Completo <span class="text-red-500">*</span></label>
          <input type="text" id="input-nombre" required class="w-full rounded-lg border-superficie-200 focus:border-yeti-500 focus:ring-yeti-500 px-3 py-2 border text-sm" placeholder="Ej. Juan Pérez">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-texto-700 mb-1">Teléfono</label>
            <input type="text" id="input-telefono" class="w-full rounded-lg border-superficie-200 focus:border-yeti-500 focus:ring-yeti-500 px-3 py-2 border text-sm" placeholder="Ej. 555-1234">
          </div>
          <div>
            <label class="block text-sm font-medium text-texto-700 mb-1">Email</label>
            <input type="email" id="input-email" class="w-full rounded-lg border-superficie-200 focus:border-yeti-500 focus:ring-yeti-500 px-3 py-2 border text-sm" placeholder="Ej. juan@correo.com">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-texto-700 mb-1">Notas Adicionales</label>
          <textarea id="input-notas" rows="2" class="w-full rounded-lg border-superficie-200 focus:border-yeti-500 focus:ring-yeti-500 px-3 py-2 border text-sm" placeholder="Información de contacto, preferencias, etc."></textarea>
        </div>

        <!-- HISTORIAL DE CONTRATACIONES -->
        <div id="seccion-historial" class="hidden mt-4 pt-4 border-t border-superficie-200">
          <h5 class="text-sm font-bold text-texto-900 mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yeti-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Historial de Contrataciones
          </h5>
          <div class="bg-superficie-50 rounded-lg p-3 border border-superficie-200 max-h-56 overflow-y-auto">
            <ul id="lista-historial" class="space-y-3 text-sm text-texto-600">
              <!-- Llenado dinámico -->
            </ul>
          </div>
        </div>

        <div class="pt-4 flex justify-end gap-3">
          <button type="button" id="btn-cancelar" class="px-4 py-2 text-sm font-medium text-texto-600 bg-white border border-superficie-200 rounded-lg hover:bg-superficie-50">Cancelar</button>
          <button type="submit" id="btn-guardar" class="px-4 py-2 text-sm font-medium text-white bg-yeti-600 rounded-lg hover:bg-yeti-700 transition-colors">Guardar Cliente</button>
        </div>
      </form>
    </div>
  </div>

</Layout>

<script>
  const API_BASE = 'http://localhost:8001/api/v1';
  let todosLosClientes: any[] = [];
  let clienteEditandoId: number | null = null;
  let paginaActual = 1;

  async function cargarClientes(pagina = 1) {
    const tbody = document.getElementById('tbody-clientes');
    if (!tbody) return;

    try {
      const res = await fetch(`${API_BASE}/clientes?per_page=100&page=${pagina}`);
      const json = await res.json();

      if (res.ok && json.exito) {
        todosLosClientes = json.datos.data;
        renderizarTabla(todosLosClientes);
        actualizarContador(json.datos.total);
      } else {
        tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-red-500">Error al cargar datos.</td></tr>`;
      }
    } catch {
      tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-red-500">Error de conexiÃ³n con el servidor.</td></tr>`;
    }
  }

  function renderizarTabla(clientes: any[]) {
    const tbody = document.getElementById('tbody-clientes');
    if (!tbody) return;

    if (clientes.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center justify-center">
              <span class="text-4xl mb-3">📇</span>
              <p class="text-texto-500 font-medium">No se encontraron clientes</p>
              <p class="text-texto-400 text-sm mt-1">Intenta con otra búsqueda o agrega un nuevo cliente.</p>
            </div>
          </td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = clientes.map(cliente => `
      <tr class="hover:bg-superficie-50/50 transition-colors group">
        <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-texto-400">#${String(cliente.id).padStart(4, '0')}</td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-texto-900">${cliente.nombre}</td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-texto-600">${cliente.telefono || '-'}</td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-texto-600">${cliente.email || '-'}</td>
        <td class="px-6 py-4 text-center whitespace-nowrap">
          <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-superficie-100 text-texto-600">
            ${cliente.eventos_count ?? 0} Eventos
          </span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
          <div class="flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="btn-editar text-yeti-600 hover:text-yeti-800 p-1 rounded hover:bg-yeti-50 transition-colors" data-id="${cliente.id}" title="Editar">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </button>
            <button class="btn-eliminar text-red-500 hover:text-red-700 p-1 rounded hover:bg-red-50 transition-colors" data-id="${cliente.id}" data-nombre="${cliente.nombre}" title="Eliminar">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  function actualizarContador(total: number) {
    const el = document.getElementById('contador-clientes');
    if (el) el.textContent = `${total} cliente${total !== 1 ? 's' : ''} registrado${total !== 1 ? 's' : ''}`;
  }

  document.getElementById('buscar-cliente')?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    const filtrados = todosLosClientes.filter(c =>
      c.nombre.toLowerCase().includes(query) ||
      (c.telefono || '').toLowerCase().includes(query) ||
      (c.email || '').toLowerCase().includes(query)
    );
    renderizarTabla(filtrados);
  });

  const modalOverlay = document.getElementById('modal-overlay');
  const modalContenido = document.getElementById('modal-contenido');

  async function abrirModal(clienteIdOObjeto?: any) {
    const titulo = document.getElementById('titulo-modal');
    const btnGuardar = document.getElementById('btn-guardar');
    const seccionHistorial = document.getElementById('seccion-historial');
    const listaHistorial = document.getElementById('lista-historial');
    document.getElementById('error-form')?.classList.add('hidden');

    // Resetear form
    (document.getElementById('form-cliente') as HTMLFormElement)?.reset();

    // Si pasamos un id (desde el botón editar) cargamos los detalles de la BD
    if (clienteIdOObjeto && typeof clienteIdOObjeto !== 'object') {
      try {
        const res = await fetch(`${API_BASE}/clientes/${clienteIdOObjeto}`);
        const data = await res.json();
        if (data.exito) {
          const cliente = data.datos;
          clienteEditandoId = cliente.id;
          if (titulo) titulo.textContent = 'Editar Cliente / Historial';
          if (btnGuardar) btnGuardar.textContent = 'Actualizar Cliente';

          (document.getElementById('input-nombre') as HTMLInputElement).value = cliente.nombre || '';
          (document.getElementById('input-telefono') as HTMLInputElement).value = cliente.telefono || '';
          (document.getElementById('input-email') as HTMLInputElement).value = cliente.email || '';
          (document.getElementById('input-notas') as HTMLInputElement).value = cliente.notas || '';

          // Llenar historial
          if (seccionHistorial && listaHistorial) {
            seccionHistorial.classList.remove('hidden');
            if (cliente.eventos && cliente.eventos.length > 0) {
              listaHistorial.innerHTML = cliente.eventos.map((ev: any) => {
                // Formatear fecha
                const fecha = new Date(ev.fecha_evento);
                const fechaLegible = fecha.toLocaleDateString('es-MX', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
                const hora = ev.hora_inicio ? ev.hora_inicio.slice(0, 5) : '';
                
                // Color por estado
                let bgEstado = 'bg-superficie-100 text-superficie-700';
                if (ev.estado === 'Cotizado') bgEstado = 'bg-yeti-100 text-yeti-700 border-yeti-200';
                if (ev.estado === 'Anticipo Pagado') bgEstado = 'bg-yeti-500 text-white shadow-sm';
                if (ev.estado === 'Confirmado') bgEstado = 'bg-frost-500 text-white shadow-sm';
                if (ev.estado === 'Completado') bgEstado = 'bg-texto-800 text-white shadow-sm';

                return `
                <li class="bg-white p-3 rounded-lg border border-superficie-200 shadow-sm hover:border-yeti-300 transition-colors cursor-default text-left flex flex-col gap-2">
                  <div class="flex justify-between items-start w-full">
                    <div>
                      <p class="font-semibold text-texto-900 capitalize text-[13px]">${fechaLegible} <span class="font-normal text-texto-500 lowercase ml-1">&bull; ${hora} hrs</span></p>
                      <p class="text-xs text-yeti-600 font-medium mt-0.5">${ev.paquete_contratado || 'Paquete no especificado'}</p>
                    </div>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border ${bgEstado}">${ev.estado}</span>
                  </div>
                  
                  <div class="mt-1 pt-2 border-t border-superficie-100 text-xs text-texto-600 flex justify-between">
                    <div class="flex gap-3">
                      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-texto-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg> ${ev.municipio || 'N/A'}</span>
                      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-texto-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg> ${ev.total_invitados || 0} pax</span>
                    </div>
                    <span class="font-medium text-texto-900">$${parseFloat(ev.total_precio || 0).toLocaleString('es-MX', {minimumFractionDigits: 2})}</span>
                  </div>
                </li>
              `}).join('');
            } else {
              listaHistorial.innerHTML = '<li class="text-texto-400 italic">No hay eventos registrados para este cliente.</li>';
            }
          }
        }
      } catch (e) {
        console.error(e);
      }
    } else {
      clienteEditandoId = null;
      if (titulo) titulo.textContent = 'Nuevo Cliente';
      if (btnGuardar) btnGuardar.textContent = 'Guardar Cliente';
      if (seccionHistorial) seccionHistorial.classList.add('hidden');
    }

    modalOverlay?.classList.remove('hidden');
    modalOverlay?.classList.add('flex');
    setTimeout(() => {
      modalContenido?.classList.remove('scale-95', 'opacity-0');
      modalContenido?.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function cerrarModal() {
    modalContenido?.classList.remove('scale-100', 'opacity-100');
    modalContenido?.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modalOverlay?.classList.add('hidden');
      modalOverlay?.classList.remove('flex');
      (document.getElementById('form-cliente') as HTMLFormElement)?.reset();
      document.getElementById('error-form')?.classList.add('hidden');
      clienteEditandoId = null;
    }, 200);
  }

  document.getElementById('tbody-clientes')?.addEventListener('click', (e) => {
    const btnEditar = (e.target as HTMLElement).closest('.btn-editar');
    if (btnEditar) {
      const id = btnEditar.getAttribute('data-id');
      if (id) abrirModal(id);
    }

    const btnEliminar = (e.target as HTMLElement).closest('.btn-eliminar');
    if (btnEliminar) {
      const id = btnEliminar.getAttribute('data-id');
      const nombre = btnEliminar.getAttribute('data-nombre');
      if (confirm(`¿Estás seguro de eliminar a ${nombre}?`)) {
        fetch(`${API_BASE}/clientes/${id}`, { method: 'DELETE' })
          .then(res => res.json())
          .then(res => {
            if (res.exito) cargarClientes(paginaActual);
            else alert(res.mensaje);
          });
      }
    }
  });

  document.getElementById('btn-agregar-cliente')?.addEventListener('click', () => abrirModal());

  document.getElementById('btn-cerrar-modal')?.addEventListener('click', cerrarModal);
  document.getElementById('btn-cancelar')?.addEventListener('click', cerrarModal);
  modalOverlay?.addEventListener('click', (e) => {
    if (e.target === modalOverlay) cerrarModal();
  });

  document.getElementById('form-cliente')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btnGuardar = document.getElementById('btn-guardar') as HTMLButtonElement;
    const errorDiv = document.getElementById('error-form');

    const nombre = (document.getElementById('input-nombre') as HTMLInputElement).value;
    const telefono = (document.getElementById('input-telefono') as HTMLInputElement).value;
    const email = (document.getElementById('input-email') as HTMLInputElement).value;
    const notas = (document.getElementById('input-notas') as HTMLTextAreaElement).value;

    btnGuardar.disabled = true;
    btnGuardar.textContent = 'Guardando...';

    const esEdicion = clienteEditandoId !== null;

    try {
      const endpoint = esEdicion ? `${API_BASE}/clientes/${clienteEditandoId}` : `${API_BASE}/clientes`;
      const metodo = esEdicion ? 'PUT' : 'POST';
      const res = await fetch(endpoint, {
        method: metodo,
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ nombre, telefono, email, notas }),
      });

      const json = await res.json();

      if (res.ok && json.exito) {
        cerrarModal();
        cargarClientes();
      } else {
        const mensajes = json.errors
          ? Object.values(json.errors).flat().join('. ')
          : json.mensaje || 'Error al guardar el cliente.';
        if (errorDiv) {
          errorDiv.textContent = mensajes;
          errorDiv.classList.remove('hidden');
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = 'Error de conexión con la API.';
        errorDiv.classList.remove('hidden');
      }
    } finally {
      btnGuardar.disabled = false;
      btnGuardar.textContent = esEdicion ? 'Actualizar Cliente' : 'Guardar Cliente';
    }
  });

  // Event Delegation para botones editar / eliminar
  document.getElementById('tbody-clientes')?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const btnEditar = target.closest('.btn-editar') as HTMLButtonElement;
    const btnEliminar = target.closest('.btn-eliminar') as HTMLButtonElement;

    if (btnEditar) {
      const id = parseInt(btnEditar.dataset.id || '0', 10);
      const cliente = todosLosClientes.find(c => c.id === id);
      if (cliente) abrirModal(cliente);
    } else if (btnEliminar) {
      const id = parseInt(btnEliminar.dataset.id || '0', 10);
      const nombre = btnEliminar.dataset.nombre || '';
      
      if (!confirm(`¿Estás seguro de eliminar a "${nombre}"? Esta acción no se puede deshacer.`)) return;

      try {
        const res = await fetch(`${API_BASE}/clientes/${id}`, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json' },
        });
        const data = await res.json();
        
        if (res.ok) {
          cargarClientes();
        } else {
          alert('No se puede eliminar: ' + (data.mensaje || 'Error desconocido'));
        }
      } catch (err) {
        alert('Error al comunicar con el servidor.');
      }
    }
  });

  // Inicializar al montar el componente
  document.addEventListener('DOMContentLoaded', () => cargarClientes());
</script>
