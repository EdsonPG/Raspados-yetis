---
/**
 * Layout Principal — Raspados Yeti ERP
 *
 * Layout base con sidebar de navegación lateral.
 * Tema claro, profesional y de alto contraste.
 *
 * @prop {string} titulo - Título de la página actual
 * @prop {string} descripcion - Meta descripción para SEO
 */
interface Props {
  titulo?: string;
  descripcion?: string;
}

const { titulo = 'Raspados Yeti ERP', descripcion = 'Sistema ERP/CRM para gestión de costos y logística de Raspados Yeti' } = Astro.props;

// Importar estilos globales (Tailwind CSS + tema Yeti)
import '../styles/global.css';

// Determinar la página activa para resaltar en el sidebar
const rutaActual = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={descripcion} />
  <title>{titulo}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- UI UX Feedback - SweetAlert2 para modales modernos -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-superficie-50 text-texto-900 font-sans antialiased min-h-screen">
  <div class="flex min-h-screen">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <aside class="w-64 bg-white border-r border-superficie-200 flex flex-col fixed h-full z-30 shadow-sm">

      <!-- Logo / Marca -->
      <div class="h-16 flex items-center gap-3 px-5 border-b border-superficie-200 bg-gradient-to-r from-yeti-600 to-yeti-700">
        <div class="w-9 h-9 rounded-lg bg-white/20 backdrop-blur flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
        <div>
          <h1 class="text-white font-bold text-sm tracking-wide">Raspados Yeti</h1>
          <span class="text-yeti-200 text-[10px] font-medium uppercase tracking-widest">ERP Sistema</span>
        </div>
      </div>

      <!-- Navegación -->
      <nav class="flex-1 py-4 px-3 space-y-1 overflow-y-auto">

        <p class="px-3 mb-2 text-[10px] font-semibold uppercase tracking-widest text-texto-400">Principal</p>

        <!-- Dashboard -->
        <a href="/" id="nav-dashboard"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
          </svg>
          Dashboard
        </a>

        <p class="px-3 mt-5 mb-2 text-[10px] font-semibold uppercase tracking-widest text-texto-400">Motor de Costeo</p>

        <!-- Insumos -->
        <a href="/insumos" id="nav-insumos"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/insumos'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/insumos' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125v-3.75" />
          </svg>
          Insumos
        </a>

        <!-- Productos / Recetas -->
        <a href="/productos" id="nav-productos"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/productos'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/productos' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" />
          </svg>
          Productos / Recetas
        </a>

        <!-- Productos -->
        <a href="/cotizador" id="nav-cotizador"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/cotizador'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/cotizador' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z" />
          </svg>
          Cotizador
        </a>

        <!-- Historial de Cotizaciones -->
        <a href="/historial" id="nav-historial"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/historial'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/historial' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
          </svg>
          Historial de Cotizaciones
        </a>

        <p class="px-3 mt-5 mb-2 text-[10px] font-semibold uppercase tracking-widest text-texto-400">Logística y CRM</p>
        <!-- Clientes -->
        <a href="/clientes" id="nav-clientes"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/clientes'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/clientes' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
          Directorio de Clientes
        </a>
        <!-- Calendario y Eventos -->
        <a href="/eventos" id="nav-eventos"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/eventos'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/eventos' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
          </svg>
          Agenda de Eventos
        </a>
        <!-- Control de Inventario -->
        <a href="/inventario" id="nav-inventario"
           class:list={[
             "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium group",
             rutaActual === '/inventario'
               ? "bg-yeti-50 text-yeti-700 border border-yeti-200"
               : "text-texto-700 hover:bg-superficie-100 hover:text-yeti-600"
           ]}>
          <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-[18px] h-[18px]", rutaActual === '/inventario' ? "text-yeti-500" : "text-texto-400 group-hover:text-yeti-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
          Control de Inventario
        </a>

        <p class="px-3 mt-5 mb-2 text-[10px] font-semibold uppercase tracking-widest text-texto-400">Sistema</p>

        <!-- Configuración (placeholder) -->
        <a href="#" id="nav-config"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-texto-400 cursor-not-allowed opacity-50">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px] text-texto-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Configuración
          <span class="ml-auto text-[9px] bg-superficie-200 text-texto-500 px-1.5 py-0.5 rounded-full font-medium">Pronto</span>
        </a>
      </nav>

      <!-- Pie del sidebar -->
      <div class="p-4 border-t border-superficie-200 bg-superficie-50">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-yeti-400 to-yeti-600 flex items-center justify-center">
            <span class="text-white text-xs font-bold">RY</span>
          </div>
          <div>
            <p class="text-xs font-semibold text-texto-900">Administrador</p>
            <p class="text-[10px] text-texto-400">Raspados Yeti</p>
          </div>
        </div>
      </div>
    </aside>

    <!-- ═══════════════ CONTENIDO PRINCIPAL ═══════════════ -->
    <main class="flex-1 ml-64">

      <!-- Header superior -->
      <header class="h-16 bg-white border-b border-superficie-200 flex items-center justify-between px-8 sticky top-0 z-20">
        <div>
          <h2 class="text-lg font-semibold text-texto-900">{titulo}</h2>
        </div>
        <div class="flex items-center gap-6">
          <!-- Indicador de API -->
          <div id="api-status" class="flex items-center gap-2 text-xs text-texto-400 border-r border-superficie-200 pr-6">
            <span class="w-2 h-2 rounded-full bg-superficie-300 animate-pulse" id="api-dot"></span>
            <span id="api-label">API desconectada</span>
          </div>

          <!-- Campana de Notificaciones -->
          <div class="relative" id="notifications-root">
            <button type="button" id="notifications-button" class="relative cursor-pointer group">
              <div class="p-2 rounded-full bg-superficie-100 group-hover:bg-superficie-200 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-texto-500 group-hover:text-yeti-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              </div>
              <!-- Badge de Notificación -->
              <span id="notifications-badge" class="hidden absolute top-1 right-1 min-w-5 h-5 px-1 rounded-full bg-red-500 border-2 border-white text-[10px] leading-4 text-white font-semibold"></span>
            </button>

            <div id="notifications-panel" class="hidden absolute right-0 mt-3 w-96 max-w-[90vw] rounded-2xl border border-superficie-200 bg-white shadow-xl overflow-hidden z-50">
              <div class="flex items-center justify-between px-4 py-3 border-b border-superficie-200 bg-superficie-50">
                <div>
                  <p class="text-sm font-semibold text-texto-900">Notificaciones</p>
                  <p class="text-xs text-texto-500" id="notifications-subtitle">Cargando...</p>
                </div>
                <button type="button" id="notifications-mark-all" class="text-xs font-medium text-yeti-600 hover:text-yeti-700">Marcar todas</button>
              </div>
              <div id="notifications-list" class="max-h-96 overflow-y-auto divide-y divide-superficie-100"></div>
              <div id="notifications-empty" class="hidden px-4 py-8 text-center text-sm text-texto-500">No hay notificaciones por ahora.</div>
            </div>
          </div>
        </div>
      </header>

      <!-- Contenido de la página -->
      <div class="p-8">
        <slot />
      </div>
    </main>

  </div>

  <!-- Script: Verificar estado de la API al cargar -->
  <script>
    const API_BASE = 'http://127.0.0.1:8001/api/v1';

    async function verificarAPI() {
      const dot = document.getElementById('api-dot');
      const label = document.getElementById('api-label');
      try {
        const res = await fetch(`${API_BASE}/insumos`, {
          signal: AbortSignal.timeout(3000)
        });
        if (res.ok) {
          dot?.classList.remove('bg-superficie-300');
          dot?.classList.add('bg-ganancia-500');
          dot?.classList.remove('animate-pulse');
          if (label) label.textContent = 'API conectada';
          if (label) label.classList.replace('text-texto-400', 'text-ganancia-600');
        }
      } catch {
        dot?.classList.remove('bg-superficie-300');
        dot?.classList.add('bg-red-400');
        if (label) label.textContent = 'API no disponible';
      }
    }

    const state = {
      items: [],
      open: false,
    };

    const notificationsRoot = document.getElementById('notifications-root');
    const notificationsButton = document.getElementById('notifications-button');
    const notificationsPanel = document.getElementById('notifications-panel');
    const notificationsList = document.getElementById('notifications-list');
    const notificationsEmpty = document.getElementById('notifications-empty');
    const notificationsBadge = document.getElementById('notifications-badge');
    const notificationsSubtitle = document.getElementById('notifications-subtitle');
    const notificationsMarkAll = document.getElementById('notifications-mark-all');

    function escapeHtml(text) {
      return text
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function formatearFecha(valor) {
      if (!valor) return '';
      const fecha = new Date(valor);
      return new Intl.DateTimeFormat('es-MX', {
        day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit'
      }).format(fecha);
    }

    function renderNotifications() {
      const unreadCount = state.items.filter((n) => !n.leida_at).length;
      if (notificationsBadge) {
        if (unreadCount > 0) {
          notificationsBadge.textContent = String(unreadCount);
          notificationsBadge.classList.remove('hidden');
        } else {
          notificationsBadge.classList.add('hidden');
        }
      }

      if (notificationsSubtitle) {
        notificationsSubtitle.textContent = unreadCount > 0
          ? `${unreadCount} sin leer`
          : 'Todo al día';
      }

      if (!notificationsList || !notificationsEmpty) return;

      if (!state.items.length) {
        notificationsList.innerHTML = '';
        notificationsEmpty.classList.remove('hidden');
        return;
      }

      notificationsEmpty.classList.add('hidden');
      notificationsList.innerHTML = state.items.map((notificacion) => {
        const esLeida = Boolean(notificacion.leida_at);
        const punto = esLeida ? 'bg-superficie-300' : 'bg-yeti-500';
        const fondo = esLeida ? 'bg-white' : 'bg-yeti-50/50';
        const accion = notificacion.accion_url || '#';
        return `
          <button type="button" data-id="${notificacion.id}" data-accion="${escapeHtml(accion)}" class="w-full text-left px-4 py-3 ${fondo} hover:bg-superficie-50 transition-colors">
            <div class="flex gap-3">
              <span class="mt-2 w-2.5 h-2.5 rounded-full ${punto} shrink-0"></span>
              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <p class="text-sm font-semibold text-texto-900 truncate">${escapeHtml(notificacion.titulo)}</p>
                  <span class="text-[11px] text-texto-400 whitespace-nowrap">${formatearFecha(notificacion.created_at)}</span>
                </div>
                <p class="mt-1 text-sm text-texto-600 leading-5">${escapeHtml(notificacion.mensaje)}</p>
              </div>
            </div>
          </button>
        `;
      }).join('');
    }

    async function cargarNotificaciones() {
      try {
        const res = await fetch(`${API_BASE}/notificaciones?limit=8`);
        const json = await res.json();
        state.items = json?.datos?.notificaciones || [];
        renderNotifications();
      } catch {
        state.items = [];
        renderNotifications();
      }
    }

    function setPanelVisible(visible) {
      state.open = visible;
      notificationsPanel?.classList.toggle('hidden', !visible);
    }

    notificationsButton?.addEventListener('click', (event) => {
      event.stopPropagation();
      setPanelVisible(!state.open);
      if (state.open) cargarNotificaciones();
    });

    notificationsMarkAll?.addEventListener('click', async () => {
      await fetch(`${API_BASE}/notificaciones/leer-todas`, { method: 'PATCH' });
      await cargarNotificaciones();
    });

    notificationsList?.addEventListener('click', async (event) => {
      const target = event.target;
      const button = target instanceof Element ? target.closest('button[data-id]') : null;
      if (!button) return;

      const id = button.dataset.id;
      const accion = button.dataset.accion || '#';
      await fetch(`${API_BASE}/notificaciones/${id}/leer`, { method: 'PATCH' });
      await cargarNotificaciones();

      if (accion && accion !== '#') {
        window.location.href = accion;
      }
    });

    document.addEventListener('click', (event) => {
      if (!state.open) return;
      const target = event.target;
      if (notificationsRoot && target instanceof Node && !notificationsRoot.contains(target)) {
        setPanelVisible(false);
      }
    });

    verificarAPI();
    cargarNotificaciones();
    setInterval(cargarNotificaciones, 30000);
  </script>
</body>
</html>
